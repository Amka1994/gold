//@version=5
indicator("XAUUSD MTF Signal [SMC]", overlay=true, max_bars_back=500)

// ════════════════════════════════════════
// INPUTS
// ════════════════════════════════════════
i_swingLen   = input.int(5,     "Swing Length",         minval=3, group="Settings")
i_zoneBuf    = input.float(1.0, "Zone Buffer (points)", minval=0.1, group="Settings")
i_showD1     = input.bool(true, "D1 Levels",            group="Display")
i_showH4     = input.bool(true, "H4 Structure",         group="Display")
i_showH1     = input.bool(true, "H1 Zones",             group="Display")

// ════════════════════════════════════════
// MULTI-TIMEFRAME DATA
// ════════════════════════════════════════
d1_high  = request.security(syminfo.tickerid, "D",   high)
d1_low   = request.security(syminfo.tickerid, "D",   low)
d1_sh    = request.security(syminfo.tickerid, "D",   ta.pivothigh(high, i_swingLen, i_swingLen))
d1_sl    = request.security(syminfo.tickerid, "D",   ta.pivotlow(low,  i_swingLen, i_swingLen))

h4_high  = request.security(syminfo.tickerid, "240", high)
h4_low   = request.security(syminfo.tickerid, "240", low)
h4_sh    = request.security(syminfo.tickerid, "240", ta.pivothigh(high, i_swingLen, i_swingLen))
h4_sl    = request.security(syminfo.tickerid, "240", ta.pivotlow(low,  i_swingLen, i_swingLen))

h1_sh    = request.security(syminfo.tickerid, "60",  ta.pivothigh(high, i_swingLen, i_swingLen))
h1_sl    = request.security(syminfo.tickerid, "60",  ta.pivotlow(low,  i_swingLen, i_swingLen))

// ════════════════════════════════════════
// D1 TREND — Dow Theory (HH/HL эсвэл LH/LL)
// ════════════════════════════════════════
var float d1_last_sh = na
var float d1_prev_sh = na
var float d1_last_sl = na
var float d1_prev_sl = na

if not na(d1_sh)
    d1_prev_sh := d1_last_sh
    d1_last_sh := d1_sh

if not na(d1_sl)
    d1_prev_sl := d1_last_sl
    d1_last_sl := d1_sl

d1_bull = not na(d1_last_sh) and not na(d1_prev_sh) and
          not na(d1_last_sl) and not na(d1_prev_sl) and
          d1_last_sh > d1_prev_sh and d1_last_sl > d1_prev_sl

d1_bear = not na(d1_last_sh) and not na(d1_prev_sh) and
          not na(d1_last_sl) and not na(d1_prev_sl) and
          d1_last_sh < d1_prev_sh and d1_last_sl < d1_prev_sl

// ════════════════════════════════════════
// H4 DOW STRUCTURE
// ════════════════════════════════════════
var float h4_last_sh = na
var float h4_prev_sh = na
var float h4_last_sl = na
var float h4_prev_sl = na

if not na(h4_sh)
    h4_prev_sh := h4_last_sh
    h4_last_sh := h4_sh

if not na(h4_sl)
    h4_prev_sl := h4_last_sl
    h4_last_sl := h4_sl

// ════════════════════════════════════════
// H4 INDUCEMENT — хамгийн сүүлийн swing high/low давах
// ════════════════════════════════════════
var bool ind_bull = false
var bool ind_bear = false

bullInd_trigger = d1_bull and not na(h4_last_sl) and
                  low < h4_last_sl and close > h4_last_sl

bearInd_trigger = d1_bear and not na(h4_last_sh) and
                  high > h4_last_sh and close < h4_last_sh

if bullInd_trigger
    ind_bull := true
    ind_bear := false

if bearInd_trigger
    ind_bear := true
    ind_bull := false

if not na(h4_sh) or not na(h4_sl)
    ind_bull := false
    ind_bear := false

// ════════════════════════════════════════
// H1 ZONE
// ════════════════════════════════════════
var float h1_last_sh = na
var float h1_last_sl = na

if not na(h1_sh)
    h1_last_sh := h1_sh

if not na(h1_sl)
    h1_last_sl := h1_sl

inBullZone = not na(h1_last_sl) and
             low  <= h1_last_sl + i_zoneBuf and
             close >= h1_last_sl - i_zoneBuf

inBearZone = not na(h1_last_sh) and
             high >= h1_last_sh - i_zoneBuf and
             close <= h1_last_sh + i_zoneBuf

// ════════════════════════════════════════
// M5 CANDLE PATTERNS
// ════════════════════════════════════════
candleSize = high - low + 0.0001

bullEngulf = close > open and close[1] < open[1] and
             close > open[1] and open <= close[1]

bearEngulf = close < open and close[1] > open[1] and
             close < open[1] and open >= close[1]

bullPin = close > open and
          (open - low) / candleSize > 0.55 and
          (high - close) / candleSize < 0.25

bearPin = close < open and
          (high - open) / candleSize > 0.55 and
          (close - low) / candleSize < 0.25

bullCandle = bullEngulf or bullPin
bearCandle = bearEngulf or bearPin

// ════════════════════════════════════════
// ATR-Д СУУРИЛСАН SL/TP
// ════════════════════════════════════════
atrLen    = input.int(14, "ATR Length", group="Settings")
slMult    = input.float(1.5, "SL Multiplier (ATR)", group="Settings")
tpMult    = input.float(3.0, "TP Multiplier (ATR)", group="Settings")

atr = ta.atr(atrLen)

// BUY: SL нь entry-с доош, TP нь дээш
buySL = close - atr * slMult
buyTP = close + atr * tpMult

// SELL: SL нь entry-с дээш, TP нь доош
sellSL = close + atr * slMult
sellTP = close - atr * tpMult

// RR харьцаа
rrRatio = tpMult / slMult

// ════════════════════════════════════════
// FINAL SIGNALS
// ════════════════════════════════════════
buyConf  = ind_bull and inBullZone and bullCandle
buyRisk  = ind_bull and inBullZone and not bullCandle

sellConf = ind_bear and inBearZone and bearCandle
sellRisk = ind_bear and inBearZone and not bearCandle

// ════════════════════════════════════════
// VISUALS
// ════════════════════════════════════════
plotshape(buyConf,  "BUY Confirm",  shape.labelup,    location.belowbar,
          color.new(color.green, 0), text="BUY ✓", textcolor=color.white, size=size.normal)
plotshape(buyRisk,  "BUY Risk",     shape.triangleup,  location.belowbar,
          color.new(color.lime, 20), size=size.small)

plotshape(sellConf, "SELL Confirm", shape.labeldown,  location.abovebar,
          color.new(color.red, 0), text="SELL ✓", textcolor=color.white, size=size.normal)
plotshape(sellRisk, "SELL Risk",    shape.triangledown, location.abovebar,
          color.new(color.orange, 20), size=size.small)

trendColor = d1_bull ? color.green : d1_bear ? color.red : color.gray
trendText  = d1_bull ? "D1: BULL" : d1_bear ? "D1: BEAR" : "D1: NEUTRAL"
var label trendLabel = na
label.delete(trendLabel)
trendLabel := label.new(bar_index, high * 1.001, trendText,
              color=trendColor, textcolor=color.white, size=size.small)

// D1 том эсэргэцэл/дэмжлэгийн шугам (цэнхэр, зузаан)
plot(i_showD1 ? d1_last_sh : na, "📘 D1 Resistance — Өдрийн том эсэргэцэл", color.new(color.blue, 40), 2)
plot(i_showD1 ? d1_last_sl : na, "📘 D1 Support — Өдрийн том дэмжлэг",      color.new(color.blue, 40), 2)

// H4 бүтцийн дээд/доод цэг (улбар шар)
plot(i_showH4 ? h4_last_sh : na, "🟠 H4 Swing High — 4 цагийн дээд цэг", color.new(color.orange, 30), 1)
plot(i_showH4 ? h4_last_sl : na, "🟠 H4 Swing Low — 4 цагийн доод цэг",  color.new(color.orange, 30), 1)

// H1 entry zone (шар)
plot(i_showH1 ? h1_last_sh : na, "🟡 H1 Zone High — 1 цагийн эсэргэцэл (entry бүс)", color.new(color.yellow, 30), 1)
plot(i_showH1 ? h1_last_sl : na, "🟡 H1 Zone Low — 1 цагийн дэмжлэг (entry бүс)",    color.new(color.yellow, 30), 1)

// Дэвсгэр өнгө: inducement болж buy/sell хайж байгаа үе
bgcolor(ind_bull ? color.new(color.green, 90) : na, title="🟢 Ногоон дэвсгэр — BUY боломж хайж байна (inducement дууссан)")
bgcolor(ind_bear ? color.new(color.red,   90) : na, title="🔴 Улаан дэвсгэр — SELL боломж хайж байна (inducement дууссан)")

// Тайлбар хайрцаг
var table infoBox = table.new(position.top_right, 1, 7, bgcolor=color.new(color.black, 60), border_color=color.gray, border_width=1)
table.cell(infoBox, 0, 0, "📊 XAUUSD MTF Signal [SMC]", text_color=color.white, text_size=size.small)
table.cell(infoBox, 0, 1, "━━━━━━━━━━━━━━━━━━━", text_color=color.gray, text_size=size.tiny)
table.cell(infoBox, 0, 2, "🔵 Цэнхэр зураас  → D1 том S/R", text_color=color.new(color.blue, 20), text_size=size.tiny)
table.cell(infoBox, 0, 3, "🟠 Улбар зураас  → H4 swing цэг", text_color=color.orange, text_size=size.tiny)
table.cell(infoBox, 0, 4, "🟡 Шар зураас     → H1 entry бүс", text_color=color.yellow, text_size=size.tiny)
table.cell(infoBox, 0, 5, "🟢 Ногоон дэвсгэр → BUY хайж байна", text_color=color.green, text_size=size.tiny)
table.cell(infoBox, 0, 6, "🔴 Улаан дэвсгэр  → SELL хайж байна", text_color=color.red, text_size=size.tiny)

// ════════════════════════════════════════
// ALERTS
// ════════════════════════════════════════
alertcondition(buyConf,
  "BUY — Confirmation",
  '{"signal":"BUY","type":"confirmation","pair":"XAUUSD","tf":"M5","d1_trend":"BULL","entry":"confirmation_candle","time":"{{time}}","price":"{{close}}","sl":"' + str.tostring(buySL, "#.##") + '","tp":"' + str.tostring(buyTP, "#.##") + '","rr":"' + str.tostring(rrRatio, "#.#") + '"}')

alertcondition(buyRisk,
  "BUY — Risk Entry",
  '{"signal":"BUY","type":"risk","pair":"XAUUSD","tf":"M5","d1_trend":"BULL","entry":"risk_entry","time":"{{time}}","price":"{{close}}","sl":"' + str.tostring(buySL, "#.##") + '","tp":"' + str.tostring(buyTP, "#.##") + '","rr":"' + str.tostring(rrRatio, "#.#") + '"}')

alertcondition(sellConf,
  "SELL — Confirmation",
  '{"signal":"SELL","type":"confirmation","pair":"XAUUSD","tf":"M5","d1_trend":"BEAR","entry":"confirmation_candle","time":"{{time}}","price":"{{close}}","sl":"' + str.tostring(sellSL, "#.##") + '","tp":"' + str.tostring(sellTP, "#.##") + '","rr":"' + str.tostring(rrRatio, "#.#") + '"}')

alertcondition(sellRisk,
  "SELL — Risk Entry",
  '{"signal":"SELL","type":"risk","pair":"XAUUSD","tf":"M5","d1_trend":"BEAR","entry":"risk_entry","time":"{{time}}","price":"{{close}}","sl":"' + str.tostring(sellSL, "#.##") + '","tp":"' + str.tostring(sellTP, "#.##") + '","rr":"' + str.tostring(rrRatio, "#.#") + '"}')
